fn is_prime(n: int) -> bool:
    if n < 2:
        return false
    var i = 2
    while i * i <= n:
        if n % i == 0:
            return false
        i += 1
    return true

fn main():
    var count = 0
    for n in range(2, 100):
        if is_prime(n):
            count += 1
    print(count)
