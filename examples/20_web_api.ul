import web
import json

type Todo:
    id: int
    title: str
    done: bool
derive(Serialize, Deserialize)

fn list_todos(req: Request) -> Response:
    return json([Todo(1, "ship ulang", false)])

fn create_todo(req: Request) -> Response:
    let t = req.body[Todo]?
    return json(t)

fn main():
    let app = web.App()
    app.get("/todos", list_todos)
    app.post("/todos", create_todo)
    app.listen(8080)
